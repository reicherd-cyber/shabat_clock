# [D12] Environment — copy to .env, never commit .env
PORT=3001
NODE_ENV=development

# Local dev (docker compose):
DATABASE_URL=mysql://user:pass@localhost:3306/shabat_clock
# Production (DigitalOcean managed MySQL) — TLS required, CA pinned via DB_CA_CERT_FILE:
# DATABASE_URL=mysql://doadmin:<password>@<cluster-host>:25060/shabat_clock?ssl={"rejectUnauthorized":true}
# DB_CA_CERT_FILE=/opt/shabat_clock/ca-certificate.crt

IVR_TOKEN=change-me
JWT_SECRET=change-me

# Server connects via localhost 1883 with superuser cred [D13]; TLS 8883 is for devices
MQTT_URL=mqtt://localhost:1883
MQTT_SERVER_USER=server
MQTT_SERVER_PASS=change-me

# Yemot outbound API for OTP calls. Blank token = dev-log mode (code printed to console).
OTP_YEMOT_TOKEN=
OTP_YEMOT_CALLER_ID=
# Legacy user:pass fallback (token preferred)
OTP_YEMOT_USER=
OTP_YEMOT_PASS=

# Email OTP delivery. Blank SMTP_HOST = dev-log mode (code printed to console).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Path to the mosquitto passwd file the provisioning service writes (optional in dev)
MOSQUITTO_PASSWD_FILE=

# Remote-Shelly onboarding (admin wizard "הכנת מכשיר מרוחק") — the public broker
# devices dial into + the broker files the app manages. Empty host = feature off.
# Production: DEVICE_MQTT_HOST=mqtt.kosher-teltech.com, DEVICE_CA_FILE=/etc/mosquitto/certs/device-ca.crt
DEVICE_MQTT_HOST=
DEVICE_MQTT_PORT=8883
DEVICE_CA_FILE=
MOSQUITTO_ACL_FILE=
MOSQUITTO_RELOAD_CMD=systemctl reload mosquitto

# "Sign in with Google" on the admin login (public client id; empty = button hidden)
GOOGLE_CLIENT_ID=

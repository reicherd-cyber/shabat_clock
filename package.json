    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.10.1",
    "mysql2": "^3.11.3",
    "nodemailer": "^9.0.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "ffmpeg-static": "^5.3.0",
    "msedge-tts": "^2.0.6"
  },
  "allowScripts": {
    "ffmpeg-static@5.3.0": true
  }
